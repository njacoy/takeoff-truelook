# Copy to .env.local and fill in. NEXT_PUBLIC_* values are inlined into the client bundle.

# --- Site identity (required) ---
NEXT_PUBLIC_SITE_URL=https://example.com
NEXT_PUBLIC_SITE_NAME=Example Site
NEXT_PUBLIC_SITE_DESCRIPTION=Award-caliber landing page.

# --- Social / OG (optional) ---
NEXT_PUBLIC_OG_IMAGE=/og.png
NEXT_PUBLIC_TWITTER_HANDLE=@example

# --- Analytics (optional — components no-op when blank) ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# --- Server-only secrets — NEVER prefix with NEXT_PUBLIC_ ---
# BLOB_READ_WRITE_TOKEN=
